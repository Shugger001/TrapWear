# Database (Postgres)
#
# Local (docker-compose): postgres://trapwear:trapwear@localhost:5432/trapwear
#
# Supabase: Project Settings → Database → Connection string → URI
# - Use the Transaction pooler (port 6543) for Next.js / long‑running dev — same URL in root .env, apps/web/.env.local, apps/admin/.env.local
# - If `pnpm db:push` errors with the pooler, temporarily use the Direct connection (port 5432) in root .env only, then switch back
# - URL‑encode special characters in the password (e.g. @ → %40)
DATABASE_URL=postgres://trapwear:trapwear@localhost:5432/trapwear

# Storefront URL (apps/web + admin "/" redirect target)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Admin app base URL used by storefront /admin redirect
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001
# Optional footer contact/social links (apps/web)
NEXT_PUBLIC_SUPPORT_EMAIL=support@trapwear.com
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_X_URL=
NEXT_PUBLIC_WHATSAPP_URL=

# Paystack — secret key from https://dashboard.paystack.com/#/settings/developer
# Leave unset (or empty) to disable hosted checkout until keys are ready; the storefront shows a clear message.
PAYSTACK_SECRET_KEY=sk_test_replace_me
# ISO currency for checkout (amount uses minor units: kobo for NGN, cents for USD, etc.)
PAYSTACK_CURRENCY=GHS
# Optional — reserved for future inline/JS integration
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

# Customer sign-in / account (apps/web) — min 32 chars
CUSTOMER_JWT_SECRET=dev_customer_jwt_change_to_random_32_chars_min_ok

# Order confirmation email via Resend (optional — skipped if unset)
RESEND_API_KEY=
# Verified sender in Resend, e.g. TrapWear <orders@yourdomain.com>
RESEND_FROM=TrapWear <onboarding@resend.dev>

# Optional: show generic maintenance page via middleware (apps/web)
MAINTENANCE_MODE=0

# Cron (apps/web) — required for /api/cron/sweep-stale-orders
# Use a long random string; pass Authorization: Bearer <CRON_SECRET> or ?secret=
CRON_SECRET=replace_with_long_random_string
# Cancel pending_payment orders older than this many minutes (min 5)
STALE_CHECKOUT_MINUTES=60

# Supabase Storage — product image uploads from apps/admin (optional)
# Project URL from Supabase → Settings → API → Project URL (same host the storefront may use later)
NEXT_PUBLIC_SUPABASE_URL=
# Service role key — server-only (never NEXT_PUBLIC_*). Used only by admin API routes, never sent to the browser.
SUPABASE_SERVICE_ROLE_KEY=
# Bucket name; create this bucket in Supabase → Storage. Default in code is product-images if unset.
SUPABASE_PRODUCT_IMAGES_BUCKET=product-images
# Comma-separated HTTPS URL prefixes for extra allowed product image URLs (e.g. CDN). Server-side validation on save.
ALLOWED_IMAGE_URL_PREFIXES=
# Optional: same prefixes for client-side checks in admin UI (if set, mirrors ALLOWED_IMAGE_URL_PREFIXES)
NEXT_PUBLIC_ALLOWED_IMAGE_URL_PREFIXES=

# Admin (apps/admin)
# Must be >= 32 characters in real environments
ADMIN_JWT_SECRET=dev_only_change_this_to_a_long_random_secret_string_ok

# Seed passwords (packages/db seed)
SEED_ADMIN_PASSWORD=TrapWear!Admin99
SEED_SUPER_PASSWORD=TrapWear!Super99
