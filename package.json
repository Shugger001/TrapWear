{
  "name": "trapwear",
  "private": true,
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "db:generate": "pnpm --filter @trapwear/db generate",
    "db:migrate": "pnpm --filter @trapwear/db migrate",
    "db:push": "pnpm --filter @trapwear/db push",
    "db:seed": "pnpm --filter @trapwear/db seed",
    "db:studio": "pnpm --filter @trapwear/db studio",
    "test": "turbo test",
    "e2e": "pnpm --filter @trapwear/web exec playwright test",
    "env:sync-db": "node scripts/sync-database-url.cjs"
  },
  "devDependencies": {
    "turbo": "^2.4.4",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@9.15.4+sha512.c2edc7a457ea753d984f624a2b44bac4d6e092c14fa2977b09ca116de2bb2c19"
}
